  "main": "index.js",
  "scripts": {
    "test": "npm run demo:test && npm run kill-switch:test",
    "dev": "cross-env MASTRA_SKIP_PEERDEP_CHECK=1 mastra dev",
    "build": "cross-env MASTRA_SKIP_PEERDEP_CHECK=1 mastra build",
    "a2a:windows:stream": "node --env-file=.env scripts/a2a-windows-stream.mjs",
    "a2a:mac:stream": "node --env-file=.env scripts/a2a-mac-stream.mjs",
    "demo:dry-run": "node scripts/windows-demo-preflight.mjs",
    "demo:test": "node --test scripts/tests/*.test.mjs",
    "demo:verify-workspace": "node scripts/verify-demo-workspace.mjs",
    "kill-switch:watch": "node --env-file=.env --import tsx src/mastra/scripts/watcher.ts",
    "kill-switch:start": "node --env-file=.env --import tsx src/mastra/scripts/watcher.ts --start-task",
    "kill-switch:test": "node --import tsx --test scripts/tests/kill-switch-state.test.ts",
    "start": "cross-env MASTRA_SKIP_PEERDEP_CHECK=1 mastra start"
  },
