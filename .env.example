# Used by the included weather agent and scorer.
OPENAI_API_KEY=your-openai-api-key

# Windows A2A server
MASTRA_HOST=0.0.0.0
# Browser-facing Windows address.
MASTRA_STUDIO_HOST=192.168.21.175
PORT=4111
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=lfm2.5-thinking

# Optional. When set, clients must send Authorization: Bearer <value>.
A2A_API_TOKEN=

# Windows -> MacBook A2A client
MAC_MASTRA_BASE_URL=http://192.168.137.3:4111
MAC_A2A_AGENT_ID=a2a-agent
MAC_MASTRA_API_PREFIX=/api
# Set this only if the MacBook Mastra server requires a bearer token.
MAC_A2A_TOKEN=

# Optional Windows-agent client command (`npm run a2a:windows:stream`).
WINDOWS_MASTRA_BASE_URL=http://127.0.0.1:4111
WINDOWS_A2A_AGENT_ID=windows-agent
WINDOWS_MASTRA_API_PREFIX=/api
# Set this to A2A_API_TOKEN when authentication is enabled.
WINDOWS_A2A_TOKEN=

# Local workspace only. This demo does not use DefraDB.
LOCAL_WORKSPACE_PATH=src/mastra/public/workspace
