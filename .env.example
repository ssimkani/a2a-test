# VM A2A server
MASTRA_HOST=0.0.0.0
# Browser-facing VM address. Set this to the VM's bridged IP when opening Studio remotely.
MASTRA_STUDIO_HOST=192.168.21.220
PORT=4111
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=qwen3:1.7b

# Optional. When set, clients must send Authorization: Bearer <value>.
A2A_API_TOKEN=

# VM -> MacBook A2A client
MAC_MASTRA_BASE_URL=http://192.168.21.97:4111
MAC_A2A_AGENT_ID=a2a-agent
MAC_MASTRA_API_PREFIX=/api
# Set this only if the MacBook Mastra server requires a bearer token.
MAC_A2A_TOKEN=
