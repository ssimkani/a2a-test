OPENAI_API_KEY=your-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# MacBook A2A server. Use 0.0.0.0 so the peer-connected Windows computer can reach it.
MASTRA_HOST=0.0.0.0
MASTRA_STUDIO_HOST=localhost
PORT=4111
# Optional. When set, the Windows client must send this value as its bearer token.
A2A_API_TOKEN=

# MacBook -> peer-connected Windows A2A client
WINDOWS_MASTRA_BASE_URL=http://192.168.21.175:4111
WINDOWS_A2A_AGENT_ID=windows-agent
WINDOWS_MASTRA_API_PREFIX=/api
# Set this to the Windows computer's A2A_API_TOKEN when authentication is enabled.
WINDOWS_A2A_TOKEN=

# Local Mac Mastra endpoint used by the demo driver.
MAC_LOCAL_MASTRA_BASE_URL=http://127.0.0.1:4111
# Set this to A2A_API_TOKEN when local API authentication is enabled.
MAC_LOCAL_A2A_TOKEN=

# Local workspace only. This demo does not use DefraDB.
LOCAL_WORKSPACE_PATH=src/mastra/public/workspace

# OrbitDB kill-switch demo. Use a unique NODE_ID and data directory per machine.
# Mac: Node Alpha. Windows: Node Bravo.
NODE_ID=Node Alpha
ORBITDB_DATA_DIR=.orbitdb/node-alpha
ORBITDB_LISTEN_ADDRESSES=/ip4/0.0.0.0/tcp/4301
ORBITDB_DATABASE_NAME=kill-switch-workflow-state

# Alpha: leave both values empty on the first run. Copy the database address and
# Alpha's /ip4/.../tcp/.../p2p/... multiaddress from Alpha's terminal to Bravo.
# Bravo: set both values before its first run.
ORBITDB_DATABASE_ADDRESS=
ORBITDB_BOOTSTRAP_MULTIADDRS=

# Native Ollama API and model. Both machines must have this model pulled.
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
KILL_SWITCH_OLLAMA_MODEL=qwen3.5:2b

# The watcher scans every 2 seconds. A foreign owner is stale after 5 seconds.
KILL_SWITCH_TIMEOUT_MS=5000
# Alpha holds here after its SAL checkpoint so the presenter can kill the node.
KILL_SWITCH_PAUSE_AFTER_SAL_MS=30000
KILL_SWITCH_TASK_ID=sitrep-demo-001
KILL_SWITCH_TRANSCRIPT_FILE=docs/sample-radio-transcript.txt
