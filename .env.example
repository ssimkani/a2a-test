OPENAI_API_KEY=your-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# MacBook A2A server. Use 0.0.0.0 so the peer-connected Windows computer can reach it.
MASTRA_HOST=0.0.0.0
MASTRA_STUDIO_HOST=localhost
PORT=4111
# Optional. When set, the Windows client must send this value as its bearer token.
A2A_API_TOKEN=

# MacBook -> peer-connected Windows A2A client
WINDOWS_MASTRA_BASE_URL=http://192.168.21.175:4111
WINDOWS_A2A_AGENT_ID=windows-agent
WINDOWS_MASTRA_API_PREFIX=/api
# Set this to the Windows computer's A2A_API_TOKEN when authentication is enabled.
WINDOWS_A2A_TOKEN=

# A2A workspace persistence. Keep "local" until the DefraDB schema is installed.
WORKSPACE_BACKEND=local
DEFRA_DB_URL=http://127.0.0.1:9181
DEFRA_DB_GRAPHQL_PATH=/api/v0/graphql
DEFRA_DB_NODE_ID=macbook
DEFRA_DB_REQUEST_TIMEOUT_MS=10000
DEFRA_DB_MAX_FILE_BYTES=10485760
