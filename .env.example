OPENAI_API_KEY=your-api-key

# MacBook A2A server. Use 0.0.0.0 so the VM can reach it over the LAN.
MASTRA_HOST=0.0.0.0
MASTRA_STUDIO_HOST=localhost
PORT=4111
# Optional. When set, VM clients must use the same value as MAC_A2A_TOKEN.
A2A_API_TOKEN=

# MacBook -> VM A2A client
VM_MASTRA_BASE_URL=http://192.168.21.220:4111
VM_A2A_AGENT_ID=vm-agent
VM_MASTRA_API_PREFIX=/api
# Set this to the VM's A2A_API_TOKEN when authentication is enabled.
VM_A2A_TOKEN=
