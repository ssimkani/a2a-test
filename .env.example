# Used by the included weather agent and scorer.
OPENAI_API_KEY=your-openai-api-key

# Windows A2A server
MASTRA_HOST=0.0.0.0
# Browser-facing Windows address.
MASTRA_STUDIO_HOST=192.168.21.175
PORT=4111
# Durable Mastra run/history storage. OrbitDB remains the workflow failover store.
MASTRA_STORAGE_URL=file:./mastra.db
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=lfm2.5-thinking

# Optional. When set, clients must send Authorization: Bearer <value>.
A2A_API_TOKEN=

# Windows -> MacBook A2A client
MAC_MASTRA_BASE_URL=http://192.168.137.3:4111
MAC_A2A_AGENT_ID=a2a-agent
MAC_MASTRA_API_PREFIX=/api
# Set this only if the MacBook Mastra server requires a bearer token.
MAC_A2A_TOKEN=

# Optional Windows-agent client command (`npm run a2a:windows:stream`).
WINDOWS_MASTRA_BASE_URL=http://127.0.0.1:4111
WINDOWS_A2A_AGENT_ID=windows-agent
WINDOWS_MASTRA_API_PREFIX=/api
# Set this to A2A_API_TOKEN when authentication is enabled.
WINDOWS_A2A_TOKEN=

# Local workspace only. This demo does not use DefraDB.
LOCAL_WORKSPACE_PATH=src/mastra/public/workspace

# OrbitDB kill-switch demo defaults for this Windows branch.
NODE_ID=Node Bravo
ORBITDB_DATA_DIR=.orbitdb/node-bravo
ORBITDB_LISTEN_ADDRESSES=/ip4/0.0.0.0/tcp/4301
ORBITDB_DATABASE_NAME=kill-switch-workflow-state

# Copy the database address and Alpha's /ip4/.../tcp/.../p2p/... multiaddress
# from the Mac terminal before Bravo's first run.
ORBITDB_DATABASE_ADDRESS=
ORBITDB_BOOTSTRAP_MULTIADDRS=

# Native Ollama API and model. Both machines must have this model pulled.
KILL_SWITCH_OLLAMA_MODEL=qwen3.5:2b

# The watcher scans every 2 seconds. A foreign owner is stale after 5 seconds.
KILL_SWITCH_TIMEOUT_MS=5000
# Alpha's graceful shutdown assigns active work to Bravo. This matches Bravo's
# NODE_ID here, so Bravo will not attempt an outbound handoff when it exits.
KILL_SWITCH_FAILOVER_NODE_ID=Node Bravo
# Alpha briefly keeps its peer connection open after committing a graceful handoff.
KILL_SWITCH_HANDOFF_GRACE_MS=750
# Bravo skips the already replicated SAL checkpoint, so it needs no demo hold.
KILL_SWITCH_PAUSE_AFTER_SAL_MS=0
KILL_SWITCH_TASK_ID=sitrep-demo-001
KILL_SWITCH_TRANSCRIPT_FILE=docs/sample-radio-transcript.txt
